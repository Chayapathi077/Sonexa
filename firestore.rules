rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global fallback
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidTemplate(data, userId) {
      return data.keys().hasAll(['id', 'userId', 'category', 'name', 'content', 'createdAt']) &&
        data.keys().size() == 6 &&
        data.id is string && data.id.size() <= 128 &&
        data.userId == userId &&
        data.category is string && data.category.size() <= 100 &&
        data.name is string && data.name.size() <= 200 &&
        data.content is string && data.content.size() <= 50000 &&
        data.createdAt is number;
    }

    function isValidReport(data, userId) {
      return data.userId == userId &&
        data.id is string && data.id.size() <= 128 &&
        data.patientName is string && data.patientName.size() <= 200 &&
        data.createdAt is number &&
        data.updatedAt is number;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /templates/{templateId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(templateId) && isValidTemplate(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(templateId) && isValidTemplate(incoming(), userId) && incoming().userId == existing().userId && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }

      match /reports/{reportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(reportId) && isValidReport(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(reportId) && isValidReport(incoming(), userId) && incoming().userId == existing().userId && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }
    }
  }
}
